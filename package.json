{
  "name": "immigration-office-management",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "server": "npx tsx watch server/src/index.ts",
    "start:server": "npx tsx server/src/index.ts",
    "server:debug": "NODE_OPTIONS='--inspect' npx tsx watch server/src/index.ts",
    "debug": "NODE_OPTIONS='--inspect' npm run server & NODE_OPTIONS='--inspect' npm run dev",
    "debug:full": "NODE_ENV=development DEBUG=* NEXT_DEBUG=1 npm run debug",
    "db:select-sqlite": "node scripts/select-schema.js sqlite",
    "db:select-postgres": "node scripts/select-schema.js postgres",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "npm run db:select-sqlite && prisma generate",
    "db:generate:postgres": "npm run db:select-postgres && prisma generate",
    "db:validate": "prisma validate",
    "db:validate:sqlite": "npm run db:select-sqlite && prisma validate",
    "db:validate:postgres": "npm run db:select-postgres && prisma validate",
    "db:push": "prisma db push",
    "db:push:sqlite": "npm run db:select-sqlite && prisma db push",
    "db:push:postgres": "npm run db:select-postgres && prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:sqlite": "npm run db:select-sqlite && prisma migrate dev",
    "db:migrate:postgres": "npm run db:select-postgres && prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate:workflows": "npx tsx prisma/migrate-workflows.ts",
    "db:seed:system-tags": "npx tsx prisma/seed-system-tags.ts",
    "db:seed:shift-config": "npx tsx prisma/seed-shift-config.ts",
    "db:seed:wrong-number": "npx tsx prisma/scripts/seed-wrong-number-tag.ts",
    "db:migrate:callback-unique-index": "node scripts/run-callback-unique-index.js",
    "db:execute:callback-unique-index": "npx prisma db execute --file prisma/migrations/add_unique_applied_callback_at_for_active/migration_postgres.sql"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/jsbarcode": "^3.11.4",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.2.0",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "docx-pdf": "^0.0.1",
    "express": "^4.18.2",
    "firebase": "^12.7.0",
    "googleapis": "^166.0.0",
    "jsbarcode": "^3.12.1",
    "jsonwebtoken": "^9.0.2",
    "libreoffice-convert": "^1.7.0",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "next": "^14.2.0",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.449",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "to-regex-range": "^5.0.1",
    "zod": "^3.25.76",
    "tailwindcss": "^3.4.4",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.2.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "@prisma/config": "^7.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.4.5"
  }
}
